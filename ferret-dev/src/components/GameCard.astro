---
interface Props {
  title: string;
  description: string;
  image: string;
  link?: string;
  tags: string[];
  slug: string;
}

const { title, description, image, link, tags, slug } = Astro.props;
---

<article class="game-card pixel-border-sm">
  <div class="game-img-wrap">
    <img src={image} alt={title} />
  </div>
  <div class="game-body">
    <div class="tags">
      {tags.map(tag => <span class="tag green">{tag}</span>)}
    </div>
    <h3>{title}</h3>
    <p>{description}</p>
    <div class="game-links">
      <a href={`/games/${slug}`} class="btn">Details</a>
      {link && <a href={link} class="btn" target="_blank" rel="noopener">Play ↗</a>}
    </div>
  </div>
</article>

<style>
  .game-card {
    background: var(--color-surface);
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .game-img-wrap {
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--color-bg);
  }

  .game-img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    image-rendering: pixelated;
  }

  .game-body {
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    flex: 1;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  h3 {
    font-size: 13px;
    color: var(--color-heading);
  }

  p {
    font-size: 9px;
    color: var(--color-text);
    line-height: 2;
  }

  .game-links {
    display: flex;
    gap: 12px;
    margin-top: auto;
  }
</style>
