---
interface Props {
  name: string;
  role: string;
  bio: string;
  photo: string;
}

const { name, role, bio, photo } = Astro.props;
---

<article class="team-card pixel-border-sm">
  <div class="photo-wrap">
    <img src={photo} alt={name} />
  </div>
  <div class="info">
    <h3>{name}</h3>
    <p class="role">{role}</p>
    <p class="bio">{bio}</p>
  </div>
</article>

<style>
  .team-card {
    background: var(--color-surface);
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 32px 24px;
    gap: 20px;
  }

  .photo-wrap {
    width: 100px;
    height: 100px;
    overflow: hidden;
    border: 3px solid var(--color-green);
    background: var(--color-bg);
  }

  .photo-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    image-rendering: pixelated;
  }

  .info {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  h3 {
    font-size: 12px;
    color: var(--color-heading);
  }

  .role {
    font-size: 8px;
    color: var(--color-green);
  }

  .bio {
    font-size: 8px;
    line-height: 2;
    color: var(--color-text);
  }
</style>
