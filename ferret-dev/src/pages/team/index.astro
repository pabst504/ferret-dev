---
import Layout from '../../layouts/Layout.astro';
import TeamCard from '../../components/TeamCard.astro';

const team = [
  {
    name: 'Harrison',
    role: 'Placeholder Role',
    bio: 'Bio coming soon.',
    photo: '/images/team/Harrison.png',
  },
  {
    name: 'Kenny',
    role: 'Placeholder Role',
    bio: 'Bio coming soon.',
    photo: '/images/team/kenny.jpg',
  },
  {
    name: 'Jimmy',
    role: 'Placeholder Role',
    bio: 'Bio coming soon.',
    photo: '/images/team/jimmy.jpg',
  },
  {
    name: 'William',
    role: 'Placeholder Role',
    bio: 'Bio coming soon.',
    photo: '/images/team/William.png',
  },
  {
    name: 'Beth',
    role: 'Placeholder Role',
    bio: 'Bio coming soon.',
    photo: '/images/team/beth.jpg',
  },
  {
    name: 'Michael',
    role: 'Placeholder Role',
    bio: 'Made this cool website.',
    photo: '/images/team/Michael.jpeg',
  },
];
---

<Layout title="Team">
  <section>
    <div class="container">
      <h2>// Meet the Team</h2>
      <div class="team-grid">
        {team.map(member => (
          <TeamCard
            name={member.name}
            role={member.role}
            bio={member.bio}
            photo={member.photo}
          />
        ))}
      </div>
    </div>
  </section>
</Layout>

<style>
  .team-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 40px;
  }
</style>
